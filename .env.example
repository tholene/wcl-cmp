WCL_CLIENT_ID=
WCL_CLIENT_SECRET=
WCL_REDIRECT_URI=http://localhost:5781/auth/callback
# Default is the Defias Brotherhood guild — set this to your own guild ID before deploying
WCL_GUILD_ID=61324
WCL_REGION=EU
API_PORT=5781
VITE_DEV_SERVER_PORT=5780

# Production: set to your deployed frontend URL to restrict CORS (e.g. https://yourapp.com)
# Localhost origins are always allowed for development.
FRONTEND_URL=

# Optional: override where export files are written (default: <project-root>/exports/player-analysis)
EXPORTS_DIR=
